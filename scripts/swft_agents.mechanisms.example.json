{
  "repo_root": "/usr1/project/k00909889/swft_reverse",
  "base_branch": "main",
  "state_dir": ".orchestrator",
  "agent_cli": "opencode",
  "model": "MiniMax-M2.7",
  "full_auto": true,
  "json_output": true,
  "enable_judge": true,
  "require_judge_approval": true,
  "judge_only_on_proposed_done": true,
  "judge_model": "MiniMax-M2.7",
  "status_interval": 20,
  "stall_seconds": 300,
  "max_rounds": 6,
  "max_retries": 2,
  "interrupt_stalled": true,
  "extra_agent_args": [
    "--add-dir",
    "/usr1/project/k00909889/swft_reverse/swft_op_example/docs",
    "--add-dir",
    "/usr1/project/k00909889/swft_reverse/swft_op_example/op_test"
  ],
  "completion_checks": {
    "required_status_keys": [
      "module",
      "scope_complete",
      "hypotheses",
      "coverage_matrix",
      "confirmed_rules",
      "refuted_rules",
      "anomalies",
      "minimal_repros",
      "artifact_correlations",
      "known_failures",
      "open_questions",
      "next_steps"
    ],
    "required_result_subdirs": [
      "probes",
      "generated",
      "logs"
    ],
    "min_counts": {
      "probes": 8,
      "generated": 8,
      "logs": 8
    },
    "require_generated_for_each_probe": true,
    "require_logs_for_each_probe": true
  },
  "common_prompt": "你是 SWFT 逆向探索任务中的一个 worker。全程使用中文回复。只在分配给你的 worktree 内工作。必须基于 swft_op_example/lib/swft/api 中的真实 SWFT API 做实验，并同时参考 swft_op_example/docs 和 swft_op_example/op_test。重要环境说明：在运行任何 SWFT 相关命令前，必须先执行 `source /usr1/project/k00909889/swft_reverse/.venv/bin/activate` 激活虚拟环境。开始正式实验前，必须先做环境自检：记录当前目录、Python 版本、关键环境变量、SWFT/Ascend 初始化命令输出，并运行一个最小 SWFT 编译或执行样例，确认能生成编译产物。如果环境自检失败，必须把 status.json 的 scope_complete 设为 false，并在 known_failures 或 anomalies 中记录失败命令和错误信息，不能把没有编译产物的 case 记为 pass。每个异常都必须扩展为一组最小实验：基线、单变量扰动、边界值、反例。保留每个 probe、generated 产物和 log。每轮结束前更新 status.json 和 summary.md。只有在范围完成且所有必需产物都存在时，才允许回复 DONE。",
  "judge_common_prompt": "你是严格的中文验收 judge。必须保守。只有 worker 明确回复了 DONE、确定性 precheck 通过、status.json 中 scope_complete=true、open_questions 为空、next_steps 为空、并且证据确实支持结论时，才能返回 done。只要缺少 probe、generated、logs、失败案例、异常实验族、环境自检记录或 artifact correlation，就返回 continue。返回必须只有一行，以 `JUDGE_JSON:` 开头，后面跟合法 JSON，包含 decision、reason、next_instruction 三个 key。",
  "nudge_prompt": "继续 `{agent_name}` 在 `{worktree}` 中的探索。请使用中文。停止前必须至少新增一组实验族，并更新 `{status_file}`。不要只复述已有结论。如果范围确实完成，且所有 probe/generated/logs/status/summary 都齐全，才允许回复 `{done_marker} ...`。\n\n上一轮最后回复摘录：\n{last_message}",
  "recovery_prompt": "`{agent_name}` 上一轮异常结束。请使用中文，从 `{worktree}` 中最新稳定状态继续，不要重复已经确认的工作。先检查 status.json，找出最高优先级的缺失证据，然后执行最小实验补齐。只有范围完全完成时，才允许回复 `{done_marker} ...`。\n\n上一轮最后回复摘录：\n{last_message}",
  "stall_prompt": "`{agent_name}` 上一轮没有实质进展或疑似卡住。请使用中文，立即重新定位：检查 status.json，找出下一项缺失证据，运行能解决它的最小实验，并记录结果。除非所有完成标准都满足，否则不要回复 DONE。\n\n上一轮最后回复摘录：\n{last_message}",
